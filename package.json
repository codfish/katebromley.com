{
  "name": "katebromley.com",
  "version": "0.0.0-semantically-released",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "fix": "eslint . --fix && npm run format",
    "format": "prettier --write \"**/*.{json,css,md}\" --config ./prettier.config.js",
    "check": "npm run lint && npm run format -- --check --no-write",
    "test": "jest --watch",
    "test:ci": "jest --coverage --silent",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "@next/third-parties": "^16.1.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "contentful": "^11.10.1",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@codfish/eslint-config": "^13.1.1",
    "@contentful/rich-text-types": "^17.2.5",
    "@swc/jest": "^0.2.36",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "autoprefixer": "^10.4.23",
    "doctoc": "^2.2.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "postcss-preset-env": "^10.6.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint-config-recommended": "^17.0.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "commitlint": {
    "extends": [
      "./node_modules/@codfish/eslint-config/commitlint.js"
    ]
  },
  "lint-staged": {
    "*.{json,css}": [
      "prettier --write --config ./prettier.config.js"
    ],
    "*.md": [
      "prettier --write --config ./prettier.config.js",
      "doctoc --title '## Table of Contents'"
    ]
  },
  "volta": {
    "node": "22.18.0"
  }
}
